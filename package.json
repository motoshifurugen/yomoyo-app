{
  "name": "yomoyo",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "prebuild": "expo prebuild",
    "start": "expo start --dev-client --host lan",
    "ios": "expo run:ios --device",
    "android": "expo run:android",
    "test": "jest --watchAll=false",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "seed:dev": "node scripts/seed-dev.js",
    "seed:dev:clean": "node scripts/seed-dev.js --clean"
  },
  "dependencies": {
    "@invertase/react-native-apple-authentication": "^2.5.1",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "firebase": "^12.10.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "@expo/vector-icons": "^15.1.1",
    "expo": "~54.0.33",
    "expo-blur": "~14.0.3",
    "expo-build-properties": "~1.0.10",
    "expo-dev-client": "~6.0.21",
    "expo-notifications": "^55.0.22",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~2.0.5",
    "i18next": "^26.0.8",
    "react": "19.1.0",
    "react-i18next": "^17.0.6",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~9.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.4",
    "prettier": "^3.3.3",
    "firebase-admin": "^12.0.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "watchman": false,
    "moduleNameMapper": {
      "^firebase/firestore$": "<rootDir>/__mocks__/firebase/firestore.js",
      "^firebase/app$": "<rootDir>/__mocks__/firebase/app.js",
      "^firebase/auth$": "<rootDir>/__mocks__/firebase/auth.js",
      "@react-native-async-storage/async-storage": "<rootDir>/__mocks__/@react-native-async-storage/async-storage.js",
      "expo-notifications": "<rootDir>/__mocks__/expo-notifications.js",
      "expo-video": "<rootDir>/__mocks__/expo-video.js",
      "expo-blur": "<rootDir>/__mocks__/expo-blur.js"
    }
  }
}
