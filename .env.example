# --- Developer-specific (required before first prebuild) ---
# Set these to your own identifiers so your local build does not collide
# with another developer's installed app on the same device.
IOS_BUNDLE_IDENTIFIER=com.yourname.yomoyo
ANDROID_PACKAGE_NAME=com.yourname.yomoyo

# --- Google Sign-In ---
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs > Web application
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# --- Google Books API ---
# Google Cloud Console > APIs & Services > Credentials > API key
EXPO_PUBLIC_GOOGLE_BOOKS_API_KEY=

# --- Firebase JS SDK (Firestore data access) ---
# Values are in GoogleService-Info.plist (iOS) / google-services.json (Android)
# Firebase Console > Project settings > General > Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
