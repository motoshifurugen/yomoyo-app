rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reading activities: any authed user can read (timeline + friends feed).
    // Only the owner can create/update/delete their own activity.
    match /readingActivities/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Follows: any authed user can read (resolves the following list).
    // Only the follower can manage their own follow records.
    match /follows/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.followerId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.followerId;
    }

    // User profiles: any authed user can read (the friends feed and following
    // list need to resolve display labels and avatars for followed users).
    // Only the user themselves can write their own profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Push tokens are private to the user.
      match /pushTokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Handle reservations: maps a human-readable handle to its owner uid.
    // Authed users can `get` a single handle by exact ID for friend lookup,
    // but `list` is denied so the collection cannot be enumerated as a
    // public directory of user IDs.
    // Only the claimed owner can create the reservation, and the handle
    // must satisfy the canonical format (defense-in-depth against a
    // misbehaving client).
    // Updates and deletes are disallowed in v1: handles are immutable.
    match /handles/{handle} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid
        && handle.matches('^[a-z0-9_]{4,20}$');
      allow update, delete: if false;
    }
  }
}
